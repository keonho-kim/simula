{
  "name": "simula",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @simula/server dev & bun --filter @simula/web dev",
    "dev:server": "bun --filter @simula/server dev",
    "dev:web": "bun --filter @simula/web dev",
    "test": "bun test",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "build": "bun --filter @simula/web build"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.1.6",
    "@langchain/core": "^1.1.5",
    "@langchain/langgraph": "^1.0.5",
    "@langchain/openai": "^1.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.12",
    "@xyflow/react": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "langchain": "^1.2.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.2.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.57.0",
    "@types/bun": "^1.3.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
